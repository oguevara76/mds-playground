{
  "name": "mds-playground",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:pages": "ng build --configuration=github-pages",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "regen:prime-bridge": "python3 scripts/regen-prime-runtime-bridge.py",
    "regen:primeng-dark": "python3 scripts/regen-primeng-dark-from-light.py",
    "regen:ejemplos": "python3 scripts/sync-ejemplos-from-core.py",
    "regen:mds": "python3 scripts/regen-mds-vars-data.py && python3 scripts/regen-prime-runtime-bridge.py",
    "mds:preflight": "python3 scripts/mds-core-preflight.py --staging .mds-core-staging",
    "mds:diff": "python3 scripts/mds-core-diff.py --staging .mds-core-staging --format markdown",
    "mds:apply": "python3 scripts/mds-core-apply.py --staging .mds-core-staging",
    "mds:qa": "python3 scripts/mds-core-qa.py --format markdown",
    "mds:component-analyze": "python3 scripts/mds-component-analyze.py",
    "mds:component-qa": "python3 scripts/mds-component-qa.py",
    "mds:component-pending": "python3 scripts/mds-component-pending.py",
    "mds:component-session": "python3 scripts/mds-component-session.py",
    "backup": "bash scripts/create-backup.sh"
  },
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "@primeuix/themes": "^2.0.3",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.21",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.3"
  }
}
