{
  "name": "mds-playground",
  "private": true,
  "scripts": {
    "setup": "pnpm install --dir apps/playground",
    "playground:start": "pnpm --dir apps/playground start",
    "playground:build": "pnpm --dir apps/playground build",
    "playground:build:pages": "pnpm --dir apps/playground build:pages",
    "legacy:serve": "pnpm dlx serve . -l 5500",
    "regen:prime-bridge": "python3 scripts/regen-prime-runtime-bridge.py",
    "regen:primeng-dark": "python3 scripts/regen-primeng-dark-from-light.py",
    "regen:ejemplos": "python3 scripts/sync-ejemplos-from-core.py",
    "regen:mds": "python3 scripts/regen-mds-vars-data.py && python3 scripts/regen-prime-runtime-bridge.py",
    "backup": "bash scripts/create-backup.sh"
  }
}
