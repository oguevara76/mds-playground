{
  "ambar": {
    "headers": {
      "primitives": "/* Primitives — Ejemplo: Ámbar #786008\n   Remapea --amber-* a la rampa ámbar oscura con base #786008 en posición 600.\n   El resto de la paleta se hereda del fichero base del MDS.\n\n   Base: #786008 → HSL(47°, 88%, 25%)  Contraste con blanco: 6:1 ✓ WCAG AA\n\n   50  #fffbeb   HSL(47, 100%, 96%)\n   100 #fff4cc   HSL(47, 100%, 90%)\n   200 #feeaa4   HSL(47,  98%, 82%)\n   300 #fcdc69   HSL(47,  96%, 70%)\n   400 #f8cc2a   HSL(47,  94%, 57%)\n   500 #c29a0a   HSL(47,  90%, 40%)\n   600 #786008 ← HSL(47,  88%, 25%)  COLOR BASE\n   700 #554407   HSL(47,  85%, 18%)\n   800 #3c2f06   HSL(46,  82%, 13%)\n   900 #292005   HSL(45,  78%,  9%)\n   950 #1b1504   HSL(44,  75%,  6%)\n*/",
      "components": "/* Components — Ejemplo: Ámbar #786008\n   #786008 es suficientemente oscuro para mantener texto blanco en botones filled.\n   Solo se ajusta el focus ring al tono oscuro de la rampa ámbar.\n*/",
      "semantic-light": "/* Semantics Light — Ejemplo: Ámbar #786008\n   #786008 tiene contraste 6:1 con blanco → texto de botones en blanco es válido.\n   Solo se ajusta el highlight para alinearlo con la gama ámbar.\n*/",
      "semantic-dark": "/* Semantics Dark — Ejemplo: Ámbar #786008\n   En dark mode el primary usa --amber-400, el tono más claro\n   de la rampa ámbar — visible sobre fondos oscuros.\n   El contraste usa --surface-900 (oscuro) definido en el MDS base.\n*/"
    },
